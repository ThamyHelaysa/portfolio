{
  "name": "migration-portfolio",
  "version": "1.0.0",
  "description": "My brand new portfolio",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npx tsx --no-warnings node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts",
    "start": "npx tsx --no-warnings node_modules/@11ty/eleventy/cmd.cjs --config=eleventy.config.ts --serve --incremental",
    "generate:previews": "node scripts/generate-previews.js",
    "typecheck": "tsc --noEmit",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/assets/styles/**/*.css\" \"src/_includes/css/**/*.css\"",
    "lint:html": "html-validate \"dist/**/*.html\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run typecheck && npm run lint && npm run test:unit",
    "check:full": "npm run check && npm run build && npm run lint:html"
  },
  "author": "Thamires H Santos",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@eslint/js": "^10.0.1",
    "@netlify/plugin-lighthouse": "^6.0.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.0.3",
    "autoprefixer": "^10.4.22",
    "cssnano": "^7.1.2",
    "esbuild": "^0.27.2",
    "eslint": "^10.1.0",
    "html-validate": "^10.11.2",
    "jsdom": "^29.0.1",
    "markdown-it-anchor": "^9.2.0",
    "postcss": "^8.5.6",
    "slugify": "^1.6.6",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "tar-fs": "^3.0.0",
    "ws": "^8.17.1"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "gsap": "^3.14.2",
    "lit": "^3.3.1"
  }
}
